# TM Alert Frontend Environment Variables
# Copy this file to .env and update values for your environment

# =============================================================================
# API Configuration
# =============================================================================
# Backend API base URL (without /api/v1 suffix)
# Development: http://localhost:8000
# Production: Your Railway/production URL
VITE_API_URL=http://localhost:8000/api/v1

# =============================================================================
# Feature Flags (Optional)
# =============================================================================
# Enable/disable specific features
# VITE_ENABLE_MFA=true
# VITE_ENABLE_SSO=true
# VITE_ENABLE_LDAP=true

# =============================================================================
# UI Configuration (Optional)
# =============================================================================
# Application title
# VITE_APP_TITLE=TM Alert

# Company name for branding
# VITE_COMPANY_NAME=Taylor Morrison

# Support email shown in UI
# VITE_SUPPORT_EMAIL=support@tmalert.com

# =============================================================================
# Map Configuration (Optional)
# =============================================================================
# Google Maps API key (if using Google Maps)
# VITE_GOOGLE_MAPS_API_KEY=your_api_key_here

# Default map center coordinates
# VITE_MAP_DEFAULT_LAT=33.4484
# VITE_MAP_DEFAULT_LNG=-112.0740

# Default map zoom level
# VITE_MAP_DEFAULT_ZOOM=10

# =============================================================================
# Rate Limiting (Optional)
# =============================================================================
# Request timeout in milliseconds
# VITE_REQUEST_TIMEOUT=30000

# Retry attempts for failed requests
# VITE_RETRY_ATTEMPTS=3

# =============================================================================
# Development Settings
# =============================================================================
# Frontend dev server port (set in vite.config.ts, not here)
# Default: 3000 (auto-switches to 3001 if 3000 is in use)

# =============================================================================
# Production Deployment
# =============================================================================
# For Vercel/Netlify deployment, set these in your platform's environment variables:
# - VITE_API_URL: Your production backend URL
# Example for Vercel:
# VITE_API_URL=https://your-railway-app.up.railway.app/api/v1
